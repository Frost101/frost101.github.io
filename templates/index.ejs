<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sadik's Portfolio</title>

  <!--
    - favicon
  -->
  <link rel="shortcut icon" href="./assets/images/3d-avatar-male_lg.webp" type="image/x-icon">

  <!--
    - custom css link
  -->
  <link rel="stylesheet" href="./assets/css/style.css">

  <!--
    - google font link
  -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
</head>

<body>

  <!--
    - #MAIN
  -->

  <main>

    <!--
      - #SIDEBAR
    -->

    <%- include('./details.ejs', {user: user}) %>

    <!--
      - #main-content
    -->

    <div class="main-content">

      <!--
        - #NAVBAR
      -->

      <nav class="navbar">
        <ul class="navbar-list">
          <li class="navbar-item">
            <button class="navbar-link active" id="about" data-nav-link>About</button>
          </li>

          <li class="navbar-item">
            <button class="navbar-link" id="skills" data-nav-link>Skills</button>
          </li>

          <li class="navbar-item">
            <button class="navbar-link" id="education" data-nav-link>Education</button>
          </li>

          <li class="navbar-item">
            <button class="navbar-link" id="experience" data-nav-link>Experience</button>
          </li>

          <li class="navbar-item">
            <button class="navbar-link" id="research" data-nav-link>Research & <br> Publications</button>
          </li>

          <li class="navbar-item">
            <button class="navbar-link" id="projects" data-nav-link>Development & <br> Other Projects</button>
          </li>

          <li class="navbar-item">
            <button class="navbar-link" id="achievements" data-nav-link>Achievements</button>
          </li>

          <li class="navbar-item">
            <button class="navbar-link" id="contributions" data-nav-link>Contributions</button>
          </li>
        </ul>
      </nav>

      <!--
        - #ABOUT
      -->

      <%- include('./about.ejs', {about: about}) %>

      <!--
        - #SKILLS
      -->

      <%- include('./skills.ejs', {skills: skills}) %>

      <!--
        - #EDUCATION
      -->

      <%- include('./education.ejs', {education: education}) %>

      <!--
        - #EXPERIENCE
      -->

      <%- include('./experiences2.ejs', {experiences: experiences}) %>

      <!--
        - #RESEARCH & PUBLICATIONS
      -->

      <%- include('./researches.ejs', {researches: researches}) %>

      <!--
        - #PROJECTS
      -->

      <%- include('./projects.ejs', {projects: projects}) %>

      <!--
        - #ACHIEVEMENTS
      -->

      <%- include('./achievements.ejs', {achievements: achievements}) %>

      <!--
        - #CONTRIBUTIONS
      -->

      <%- include('./contributions.ejs', {contributions: contributions}) %>

    </div>

  </main>

  <!--
    - custom js link
  -->
  <script src="./assets/js/script.js"></script>

  <!--
    - ionicon link
  -->
  <script type="module" src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.esm.js"></script>
  <script nomodule src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.js"></script>

</body>

</html>
